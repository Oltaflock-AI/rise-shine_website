# Copy to `.env.local` and fill in. `.env.local` is git-ignored — never commit real keys.

# ── Supabase (customer accounts) ──────────────────────────────────────────────
# From: Supabase dashboard → Project Settings → API.
# Both are safe to expose to the browser; data is protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — SERVER ONLY, bypasses RLS. Needed later to write booking
# history from the TBO flow. Do NOT prefix with NEXT_PUBLIC_ and never ship to the client.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── TBO (TekTravels) flight API ───────────────────────────────────────────────
# Agency creds (Authenticate → TokenId flow). Also reused by the hotel booking
# flow and the hotel post-booking (GetBookingDetail/Voucher/Cancel) calls.
TBO_CLIENT_ID=
TBO_USERNAME=
TBO_PASSWORD=
TBO_END_USER_IP=
# Optional: override the Book/Ticket service URL if TBO provisions AirBook.
# TBO_BOOK_URL=

# ── TBO Hotel API — STATIC data (Basic auth, shared static-data creds) ────────
# Powers CountryList / CityList / TBOHotelCodeList / HotelDetails. These are the
# "static data credentials" TBO sent separately — NOT your agency login.
# Host per docs; override only if your creds email says otherwise.
TBO_HOTEL_STATIC_URL=http://api.tbotechnology.in/TBOHolidays_HotelAPI
TBO_HOTEL_STATIC_USERNAME=
TBO_HOTEL_STATIC_PASSWORD=

# ── TBO Hotel API — booking (Basic auth, your AGENCY creds) ───────────────────
# Powers Search / PreBook / Book. Agency creds = your flight login per TBO;
# leave USER/PASS blank to reuse TBO_USERNAME / TBO_PASSWORD, or set explicitly.
# Host is contradictory in the docs (affiliate.tektravels.com vs tbotechnology) —
# confirmed by the Phase-1 smoke test; override here once known.
TBO_HOTEL_URL=https://affiliate.tektravels.com/HotelAPI
# TBO_HOTEL_USERNAME=
# TBO_HOTEL_PASSWORD=

# ── Google Places (live reviews on the testimonial section) ───────────────────
# SERVER ONLY. From: Google Cloud Console → APIs & Services → Credentials.
# Enable "Places API" (legacy — allows newest-first review sort) and/or
# "Places API (New)" on the key's project; the code tries legacy first, then New.
# Without a key the site falls back to the static testimonials in src/data/.
GOOGLE_MAPS_API_KEY=
# Optional: pin the listing's Place ID to skip the text-search lookup.
# Find it: https://developers.google.com/maps/documentation/places/web-service/place-id
# GOOGLE_PLACE_ID=

# ── Razorpay (checkout / payments) ────────────────────────────────────────────
# From: Razorpay Dashboard → Settings → API Keys → Generate Key. Use TEST keys
# (rzp_test_…) until go-live, then swap for LIVE keys (rzp_live_…).
# KEY_ID is handed to the browser to open Checkout; KEY_SECRET is SERVER ONLY —
# never prefix it with NEXT_PUBLIC_ and never commit it. With both set, payment is
# ENFORCED before any ticket is issued; without them, booking degrades to the
# legacy direct-ticket path (dev/staging only).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret — a SEPARATE secret you set in Dashboard → Settings → Webhooks when
# you add the /api/payment/webhook endpoint (events: payment.captured, payment.failed,
# refund.processed). Powers the reconciliation ledger; leave blank to disable webhooks.
RAZORPAY_WEBHOOK_SECRET=

# ── Resend (transactional email) ──────────────────────────────────────────────
# From: resend.com → API Keys. With a key set, booking confirmations (flight PNR /
# hotel confirmation no.) and refund notices are emailed to the lead passenger.
# Without it, email is silently skipped — bookings are never blocked on email.
RESEND_API_KEY=
# Verified sender, e.g. "Rise & Shine Travels <bookings@yourdomain.com>". Needs the
# domain verified in Resend; defaults to Resend's onboarding sender (testing only).
EMAIL_FROM=
# Where ops alerts (failed refunds, post-capture booking failures) are sent.
# Defaults to the agency inbox in src/data/site.ts. Requires RESEND_API_KEY.
ALERT_EMAIL=
# Vercel Cron auth — Vercel sends "Authorization: Bearer <CRON_SECRET>" to cron
# routes (/api/cron/reconcile). Generate any long random string and set it in
# Vercel env; without it the cron route refuses to run.
CRON_SECRET=
